<div class="page-header">
  <h1>MUGEN OOTQ Ranking Wiki</h1>
  <div class="search-box">
    <input type="search" id="searchInput" data-i18n-placeholder="search" placeholder="搜索...">
  </div>
</div>

<section class="section">
  <div class="section-header">
    <h2 data-i18n="characters">角色</h2>
    <a href="<%= r('characters/') %>" style="font-size:0.9em;">查看全部 →</a>
  </div>
  <div class="card-grid" id="charactersGrid">
    <% characters.forEach((char, idx) => { %>
      <a class="card char-card" href="<%= r('characters/') %><%= char.slug %>/">
        <div style="display:flex;justify-content:space-between;align-items:start;margin-bottom:8px;">
          <h3 class="char-title" data-lang='<%= JSON.stringify(char.meta.title).replace(/'/g, "\\'") %>'><%= getField(char.meta.title, 'zh') %></h3>
          <% if (char.meta.ootqLevel) { %>
            <span class="ootq-badge ootq-<%= char.meta.ootqTier || 'low' %> char-ootq" data-lang='<%= JSON.stringify(char.meta.ootqLevel).replace(/'/g, "\\'") %>'><%= getField(char.meta.ootqLevel, 'zh') %></span>
          <% } %>
        </div>
        <p class="char-summary" data-lang='<%= JSON.stringify(char.meta.summary).replace(/'/g, "\\'") %>'><%= getField(char.meta.summary, 'zh') %></p>
      </a>
    <% }); %>
    <% if (characters.length === 0) { %>
      <div class="empty-state">
        <p data-i18n="noContent">暂无角色</p>
      </div>
    <% } %>
  </div>
</section>

<section class="section">
  <div class="section-header">
    <h2 data-i18n="glossary">术语</h2>
    <a href="<%= r('glossary/') %>" style="font-size:0.9em;">查看全部 →</a>
  </div>
  <div class="card-grid" id="glossaryGrid">
    <% terms.forEach((term, idx) => { %>
      <a class="card glossary-card" href="<%= r('glossary/') %><%= term.slug %>/">
        <h3 class="term-title" data-lang='<%= JSON.stringify(term.meta.title).replace(/'/g, "\\'") %>'><%= getField(term.meta.title, 'zh') %></h3>
        <% if (term.meta.summary) { %>
          <p class="term-summary" data-lang='<%= JSON.stringify(term.meta.summary).replace(/'/g, "\\'") %>'><%= getField(term.meta.summary, 'zh') %></p>
        <% } %>
      </a>
    <% }); %>
    <% if (terms.length === 0) { %>
      <div class="empty-state">
        <p data-i18n="noContent">暂无术语</p>
      </div>
    <% } %>
  </div>
</section>
