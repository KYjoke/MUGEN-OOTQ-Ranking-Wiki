<div class="page-header">
  <h1>角色</h1>
  <p class="lead">所有已收录的角色列表</p>
</div>

<div class="card-grid">
  <% characters.forEach(char => { %>
    <a class="card" href="<%= r('') %><%= char.slug %>/">
      <% if (char.image) { %>
        <img src="<%= char.slug %>/assets/<%= char.image %>" alt="<%= char.title %>" style="width:100%;height:150px;object-fit:cover;border-radius:4px;margin-bottom:10px;">
      <% } %>
      <h3><%= char.title %></h3>
      <% if (char.summary) { %>
        <p><%= char.summary %></p>
      <% } %>
      <% if (char.ootqLevel) { %>
        <p><strong>OOTQ:</strong> <%= char.ootqLevel %></p>
      <% } %>
      <% if (char.tags && char.tags.length) { %>
        <div class="tags">
          <% char.tags.slice(0, 3).forEach(tag => { %>
            <span class="tag"><%= tag %></span>
          <% }); %>
        </div>
      <% } %>
    </a>
  <% }); %>
  <% if (characters.length === 0) { %>
    <div class="empty-state">
      <p>暂无角色</p>
    </div>
  <% } %>
</div>
